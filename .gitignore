# ============================================================
# Python cache files
# ============================================================
# Python이 실행 중 자동으로 만드는 캐시 폴더/파일입니다.
# 제출이나 GitHub 업로드에 필요 없습니다.
__pycache__/
*.py[cod]
*$py.class

# ============================================================
# Virtual environments
# ============================================================
# 가상환경 폴더는 용량이 크고, 컴퓨터마다 새로 만드는 것이 맞습니다.
# 실행 환경은 requirements.txt로 재현합니다.
venv/
.venv/
env/
ENV/

# ============================================================
# Streamlit local config
# ============================================================
# 개인 환경 설정이나 비밀키가 들어갈 수 있는 파일은 업로드하지 않습니다.
.streamlit/secrets.toml

# ============================================================
# Environment variables
# ============================================================
# API key, 비밀번호 같은 개인 환경 변수를 저장하는 파일입니다.
.env
.env.*

# ============================================================
# OS/editor files
# ============================================================
# 운영체제나 에디터가 자동으로 만드는 불필요한 파일입니다.
.DS_Store
Thumbs.db
.vscode/
.idea/

# ============================================================
# Test/cache folders
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
# Build outputs
# ============================================================
build/
dist/
*.egg-info/
